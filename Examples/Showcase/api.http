###############################################################################
# Showcase Banking API — works against BOTH the MVC host and the Minimal API host
#
# Same domain, same DTOs, same JSON payloads — only the hosting style differs.
# Every request below is host-agnostic: switch the @host variable to point at
# whichever host you started.
#
# Pick a host with the environment selector (Visual Studio: top-right of editor;
# VS Code REST Client: status bar). Available environments are defined in
# http-client.env.json next to this file:
#
#   mvc          -> https://localhost:61223  (Showcase.Mvc, Kestrel)
#   minimalapi   -> http://localhost:5180    (Showcase.MinimalApi, Kestrel)
#
# Run a host:
#   dotnet run --project Examples/Showcase/src/Showcase.Mvc
#   dotnet run --project Examples/Showcase/src/Showcase.MinimalApi
#
# Open <host>/scalar/v1 for the interactive API explorer.
#
# Seed accounts created on startup:
#   Customer | Account ID                              | Type     | Balance
#   ---------|-----------------------------------------|----------|--------
#   Alice    | aaaaaaa1-0000-0000-0000-000000000000    | Checking | $1,000
#   Alice    | aaaaaaa2-0000-0000-0000-000000000000    | Savings  | $5,000
#   Bob      | bbbbbbb1-0000-0000-0000-000000000000    | Checking | $250
#   (8 filler accounts cccccccc-0000-0000-0000-000000000001..8 — for pagination demo)
#
#   Customer IDs:
#     Alice = 11111111-1111-1111-1111-111111111111
#     Bob   = 22222222-2222-2222-2222-222222222222
###############################################################################

###############################################################################
# Accounts — list / get / open / freeze / unfreeze / close
###############################################################################

### List accounts — paginated (server hard-cap = 5)
### Body envelope (`items`, `next`, `previous`, `requestedLimit`, `appliedLimit`,
### `deliveredCount`, `wasCapped`) is co-emitted with an RFC 8288 `Link` header.
### Behaviour is identical on both hosts (MVC and Minimal API).
GET {{host}}/api/accounts?limit=10
Accept: application/json

### List accounts — follow the `next` cursor returned by the previous request.
### Replace the placeholder below with the value of `next.cursor` from the
### body (or just GET the URL from the `Link: <…>; rel="next"` header).
### (Under automated replay the placeholder is still sent verbatim, which is
### rejected as 400 from Error.BadRequest("invalid_cursor") — same code path
### as the dedicated malformed-cursor case below.)
# @expect status: 400
GET {{host}}/api/accounts?limit=5&cursor=REPLACE_WITH_NEXT_CURSOR
Accept: application/json

### List accounts — malformed cursor (400 from Error.BadRequest("invalid_cursor"))
# @expect status: 400
GET {{host}}/api/accounts?cursor=not-a-real-cursor
Accept: application/json

### Get account by id
GET {{host}}/api/accounts/{{aliceChecking}}
Accept: application/json

### Get account — not found (404 from Error.NotFound)
# @expect status: 404
GET {{host}}/api/accounts/00000000-0000-0000-0000-000000000099
Accept: application/json

### Get account — malformed id (404 from Trellis route constraint).
### Both hosts register `AddTrellisRouteConstraint<AccountId>()`, so the
### `{id:AccountId}` template rejects any value that fails AccountId.TryParse
### before the request ever reaches the endpoint. The response is a routing
### 404 — no handler is invoked, no model-binding error is produced.
# @expect status: 404
GET {{host}}/api/accounts/not-a-guid
Accept: application/json

### Open new account (201 Created)
POST {{host}}/api/accounts
Content-Type: application/json
Accept: application/json

{
  "customerId": "{{aliceCustomer}}",
  "accountType": "Checking",
  "initialDeposit":       { "amount": 250.00, "currency": "USD" },
  "dailyWithdrawalLimit": { "amount": 500.00, "currency": "USD" },
  "overdraftLimit":       { "amount":   0.00, "currency": "USD" }
}

### Open account — invalid Money (negative amount fails value-level validation → 422)
### @parity: status-only
# @expect status: 422
POST {{host}}/api/accounts
Content-Type: application/json
Accept: application/json

{
  "customerId": "{{aliceCustomer}}",
  "accountType": "Checking",
  "initialDeposit":       { "amount": -100.00, "currency": "USD" },
  "dailyWithdrawalLimit": { "amount":  500.00, "currency": "USD" },
  "overdraftLimit":       { "amount":    0.00, "currency": "USD" }
}

### Freeze account
POST {{host}}/api/accounts/{{aliceChecking}}/freeze
Content-Type: application/json

{
  "reason": "Suspected fraud — investigation pending"
}

### Unfreeze account
POST {{host}}/api/accounts/{{aliceChecking}}/unfreeze

### Unfreeze an Active account (422 from Error.UnprocessableContent — invalid state transition)
# @expect status: 422
POST {{host}}/api/accounts/{{bobChecking}}/unfreeze

### Close account — fails (409 from Error.Conflict) because balance is non-zero.
### Close requires the balance to be exactly zero; withdraw or transfer the
### remaining funds first, then retry.
# @expect status: 409
POST {{host}}/api/accounts/{{bobChecking}}/close

###############################################################################
# Money operations — deposit / withdraw / secure-withdraw / interest
###############################################################################

### Deposit
POST {{host}}/api/accounts/{{aliceChecking}}/deposit
Content-Type: application/json

{
  "amount": { "amount": 500.00, "currency": "USD" },
  "description": "Payroll"
}

### Deposit — zero amount (422 from BankAccount.Deposit domain rule)
# @expect status: 422
POST {{host}}/api/accounts/{{aliceChecking}}/deposit
Content-Type: application/json

{
  "amount": { "amount": 0.00, "currency": "USD" }
}

### Withdraw
POST {{host}}/api/accounts/{{aliceChecking}}/withdraw
Content-Type: application/json

{
  "amount": { "amount": 100.00, "currency": "USD" },
  "description": "ATM"
}

### Withdraw above daily limit (409 from Error.Conflict)
# @expect status: 409
POST {{host}}/api/accounts/{{aliceChecking}}/withdraw
Content-Type: application/json

{
  "amount": { "amount": 10000.00, "currency": "USD" }
}

### Secure withdraw — withdrawals greater than $1,000 require a verification
### code. The in-memory verifier returns:
###   * 401 Error.Unauthorized        when the code is "000000" or empty
###   * 422 Error.UnprocessableContent when the code is not exactly six digits
### Use a six-digit code other than "000000" (e.g. "123456") for the happy path.
# @expect status: 401
POST {{host}}/api/accounts/{{aliceChecking}}/secure-withdraw
Content-Type: application/json

{
  "amount": { "amount": 1500.00, "currency": "USD" },
  "verificationCode": "000000"
}

### Pay interest (annual rate as decimal — 0.05 = 5%)
POST {{host}}/api/accounts/{{aliceSavings}}/interest
Content-Type: application/json

{
  "annualRate": 0.05
}

###############################################################################
# Transfers
###############################################################################

### Transfer between accounts
POST {{host}}/api/transfers/{{aliceChecking}}
Content-Type: application/json

{
  "toAccountId": "{{aliceSavings}}",
  "amount": { "amount": 250.00, "currency": "USD" },
  "description": "Monthly savings"
}

###############################################################################
# Diagnostics — deterministic Error.InternalServerError(faultId) demo
###############################################################################

### Trigger fault (500 with stable faultId in Problem Details)
# @expect status: 500
GET {{host}}/api/diagnostics/fault
Accept: application/json
