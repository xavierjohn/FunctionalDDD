{
  "metadata": [
    {
      "src": [
        {
          "src": "../..",
          "files": [
            "Trellis.Results/src/Trellis.Results.csproj",
            "Trellis.DomainDrivenDesign/src/Trellis.DomainDrivenDesign.csproj",
            "Trellis.FluentValidation/src/Trellis.FluentValidation.csproj",
            "Trellis.Asp/src/Trellis.Asp.csproj",
            "Trellis.Http/src/Trellis.Http.csproj",
            "Trellis.Primitives/src/Trellis.Primitives.csproj",
            "Trellis.Testing/src/Trellis.Testing.csproj",
            "Trellis.Stateless/src/Trellis.Stateless.csproj"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "articles/**.md",
          "articles/**/toc.yml",
          "toc.yml",
          "*.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "globalMetadata": {
      "_appTitle": "Trellis",
      "_appLogoPath": "/images/iconsmall.png"
    },
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [
      "default",
      "modern"
    ],
    "postProcessors": [],
    "keepFileLink": false,
    "disableGitFeatures": false
  }
}
