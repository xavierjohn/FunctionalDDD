{
  "metadata": [
    {
      "src": [
        {
          "src": "../..",
          "files": [
            "Trellis.Core/src/Trellis.Core.csproj",
            "Trellis.FluentValidation/src/Trellis.FluentValidation.csproj",
            "Trellis.Asp/src/Trellis.Asp.csproj",
            "Trellis.Asp.ApiVersioning/src/Trellis.Asp.ApiVersioning.csproj",
            "Trellis.Http/src/Trellis.Http.csproj",
            "Trellis.Primitives/src/Trellis.Primitives.csproj",
            "Trellis.ServiceDefaults/src/Trellis.ServiceDefaults.csproj",
            "Trellis.Testing/src/Trellis.Testing.csproj",
            "Trellis.Testing.AspNetCore/src/Trellis.Testing.AspNetCore.csproj",
            "Trellis.StateMachine/src/Trellis.StateMachine.csproj",
            "Trellis.Authorization/src/Trellis.Authorization.csproj",
            "Trellis.Mediator/src/Trellis.Mediator.csproj",
            "Trellis.EntityFrameworkCore/src/Trellis.EntityFrameworkCore.csproj"
          ]
        }
      ],
      "dest": "api",
      "disableAnalyzers": true,
      "properties": {
        "TrellisDocfxMetadataBuild": "true"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "articles/**.md",
          "articles/**/toc.yml",
          "api_reference/**.md",
          "api_reference/**/toc.yml",
          "adr/**.md",
          "toc.yml",
          "*.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "globalMetadata": {
      "_appTitle": "Trellis",
      "_appLogoPath": "/images/iconsmall.png"
    },
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [
      "default",
      "modern"
    ],
    "postProcessors": [],
    "keepFileLink": false,
    "disableGitFeatures": false
  }
}
