<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageReadmeFile>NUGET_README.md</PackageReadmeFile>
    <Description>EF Core integration for Trellis. Convention-based value converter registration for Trellis primitives, Result-returning SaveChanges wrappers, Maybe/Result query extensions, and provider-agnostic database exception classification.</Description>
    <PackageTags>trellis;efcore;entity-framework-core;value-converters;railway-oriented;result;maybe;ddd;domain-driven-design</PackageTags>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <TrellisApiRefName>efcore</TrellisApiRefName>
    <!--
      EF Core relies on runtime reflection (model building, change tracking, query translation,
      proxies). Microsoft documents NativeAOT support for EF Core as "highly experimental, not
      suited for production use" — see https://learn.microsoft.com/ef/core/performance/nativeaot-and-precompiled-queries.
      Trellis.EntityFrameworkCore therefore explicitly opts out of the AOT/trim story. Consumers
      who need AOT should use Trellis.Core + a non-EF persistence layer (see Showcase.MinimalApi).
    -->
    <IsAotCompatible>false</IsAotCompatible>
    <IsTrimmable>false</IsTrimmable>
    <EnableAotAnalyzer>false</EnableAotAnalyzer>
    <EnableTrimAnalyzer>false</EnableTrimAnalyzer>
  </PropertyGroup>
  <ItemGroup>
    <None Include="../NUGET_README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Trellis.Authorization\src\Trellis.Authorization.csproj" />
    <ProjectReference Include="..\..\Trellis.Core\src\Trellis.Core.csproj" />
    <ProjectReference Include="..\..\Trellis.Primitives\src\Trellis.Primitives.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Mediator.Abstractions" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>

  <!--
    Bundle the Trellis.EntityFrameworkCore.Generator into Trellis.EntityFrameworkCore.nupkg
    under analyzers/dotnet/cs. Source-tree
    consumers reference the generator csproj directly via OutputItemType="Analyzer"
    (see tests/, generator-tests/). NuGet consumers get the generator transparently
    via the bundled dll.
  -->
  <ItemGroup>
    <ProjectReference Include="..\generator\Trellis.EntityFrameworkCore.Generator.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false"
                      />
  </ItemGroup>

  <Target Name="_GetEfCoreGeneratorTargetPath" Returns="@(_EfCoreGeneratorTargetPath)">
    <MSBuild Projects="..\generator\Trellis.EntityFrameworkCore.Generator.csproj" Targets="GetTargetPath">
      <Output TaskParameter="TargetOutputs" ItemName="_EfCoreGeneratorTargetPath" />
    </MSBuild>
  </Target>

  <Target Name="_PackEfCoreGenerator" BeforeTargets="_GetPackageFiles" DependsOnTargets="_GetEfCoreGeneratorTargetPath">
    <ItemGroup>
      <None Include="@(_EfCoreGeneratorTargetPath)"
            Pack="true"
            PackagePath="analyzers/dotnet/cs"
            Visible="false" />
    </ItemGroup>
  </Target>
</Project>
